  "quality_rules": {
    "catalog_source": "qualities.json",
    "catalog_filter": {
      "source_includes": "CRB"
    },
    "positive_collection": "positive_qualities",
    "negative_collection": "negative_qualities",
    "default_max_selections": 1,
    "cost_resolution": {
      "positive_fixed_field": "karma_cost",
      "negative_fixed_field": "karma_bonus",
      "rated_pattern": "{amount} per rating|level",
      "option_value_fields": [
        "karma_cost",
        "karma_bonus"
      ],
      "composite_qualities": {
        "allergy": {
          "sum_option_paths": [
            "rarity",
            "severity"
          ],
          "value_field": "karma_value"
        },
        "prejudiced": {
          "sum_option_paths": [
            "target_prevalence",
            "degree"
          ],
          "value_field": "karma_value"
        }
      }
    },
    "constraints": {
      "aptitude": {
        "max_selections": 1,
        "required_parameters": [
