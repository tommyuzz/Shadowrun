  "priority_system": {
    "ranks": [
      "A",
      "B",
      "C",
      "D",
      "E"
    ],
    "categories": [
      "metatype",
      "attributes",
      "magic_or_resonance",
      "skills",
      "resources"
    ],
    "assignment": "bijection",
    "rules": [
      {
        "id": "priority.complete",
        "assertion": "Every category has exactly one priority rank."
      },
      {
        "id": "priority.unique",
        "assertion": "Every rank A through E is used exactly once."
      },
      {
        "id": "priority.option-exists",
        "assertion": "The chosen metatype and Magic or Resonance path exist at their assigned ranks."
      }
    ],
    "source_pages": [
      65
    ]
  },
  "play_level_rules": {
    "level_ids": [
      "regular",
      "street_level",
      "prime_runner"
    ],
    "values_source": "priority_array.json#/play_levels",
    "resource_values_source": "priority_array.json#/priority_array/{rank}/resources/{play_level}",
    "positive_quality_karma_cap": {
      "op": "path",
      "path": "play_level.starting_karma"
    },
    "negative_quality_karma_cap": {
      "op": "subtract",
      "args": [
        {
          "op": "path",
          "path": "play_level.maximum_karma"
        },
        {
          "op": "path",
          "path": "play_level.starting_karma"
        }
      ]
    },
    "karma_to_nuyen_rate": 2000,
    "source_pages": [
      64,
      71,
      94,
      98
    ]
  },
