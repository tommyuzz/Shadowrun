// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Rule-backed relationship presentation contract > keeps the weapon, support and equipment relationship markup unchanged 1`] = `
{
  "equipment": "<article class="market-listing" aria-labelledby="listing-title"><header class="listing-banner"><div><span>Verified catalogue entry</span><h2 id="listing-title">Product specification</h2></div><strong>EQ-001</strong></header><div class="listing-grid"><div class="product-summary"><p class="stock-label" data-status="open-market">Open market</p><div class="price-block"><span>Advertised price</span><strong>Capacity x 100¥</strong></div><dl><div><dt>Availability</dt><dd>—</dd></div><div><dt>Product class</dt><dd>Optical &amp; Imaging Devices</dd></div></dl></div><section class="product-specifications"><h3>Technical specifications</h3><dl><div><dt>Capacity</dt><dd>1-6</dd></div></dl></section></div><div class="seller-strip"><span>Seller note</span><strong>Configuration planning available below // Reference transaction only</strong></div></article><section class="section product-description"><h2 class="section-title">Product description</h2><p>An imaging device that records still images and video and can hold vision enhancements.</p></section><details class="equipment-enhancement-builder"><summary><span><small>Single-record configuration</small>Available enhancements</span><strong>7</strong></summary><div class="equipment-builder-content"><header class="equipment-builder-heading"><div><span>Configure purchase</span><h2>Build Camera</h2></div><p>Select compatible additions to assemble a readable purchase plan. Rating-dependent prices remain as authored line items.</p></header><div class="equipment-enhancement-groups"><section><div class="equipment-enhancement-group-heading"><h3>Vision enhancements</h3><span>7 options</span></div><div class="equipment-enhancement-grid"><label class="equipment-enhancement-card"><input type="checkbox"/><span class="equipment-enhancement-check" aria-hidden="true">+</span><span class="equipment-enhancement-copy"><strong>Flare Compensation (Vision Enhancement)</strong><small>CRB</small><p>Automatically protects against glare and sudden bright flashes.</p><span class="equipment-enhancement-note">Sensor housings require an installed Camera Sensor Function. Capacity and device-rating limits still apply.</span></span><span class="equipment-enhancement-specs"><b>+250¥</b><small>Capacity [1]</small></span></label><label class="equipment-enhancement-card"><input type="checkbox"/><span class="equipment-enhancement-check" aria-hidden="true">+</span><span class="equipment-enhancement-copy"><strong>Image Link (Vision Enhancement)</strong><small>CRB</small><p>Displays visual information, AR objects, video, and device output directly in the user&#x27;s field of view.</p><span class="equipment-enhancement-note">Sensor housings require an installed Camera Sensor Function. Capacity and device-rating limits still apply.</span></span><span class="equipment-enhancement-specs"><b>+25¥</b><small>Capacity [1]</small></span></label><label class="equipment-enhancement-card"><input type="checkbox"/><span class="equipment-enhancement-check" aria-hidden="true">+</span><span class="equipment-enhancement-copy"><strong>Low-Light Vision (Vision Enhancement)</strong><small>CRB</small><p>Amplifies available light, allowing effective vision in dim conditions.</p><span class="equipment-enhancement-note">Sensor housings require an installed Camera Sensor Function. Capacity and device-rating limits still apply.</span></span><span class="equipment-enhancement-specs"><b>+500¥</b><small>Capacity [1]</small></span></label><label class="equipment-enhancement-card"><input type="checkbox"/><span class="equipment-enhancement-check" aria-hidden="true">+</span><span class="equipment-enhancement-copy"><strong>Smartlink (Vision Enhancement)</strong><small>CRB</small><p>Provides the visual interface required to receive full smartgun benefits.</p><span class="equipment-enhancement-note">Sensor housings require an installed Camera Sensor Function. Capacity and device-rating limits still apply.</span></span><span class="equipment-enhancement-specs"><b>+2,000¥</b><small>Capacity [1]</small></span></label><label class="equipment-enhancement-card"><input type="checkbox"/><span class="equipment-enhancement-check" aria-hidden="true">+</span><span class="equipment-enhancement-copy"><strong>Thermographic Vision (Vision Enhancement)</strong><small>CRB</small><p>Displays heat patterns and allows vision based on infrared radiation.</p><span class="equipment-enhancement-note">Sensor housings require an installed Camera Sensor Function. Capacity and device-rating limits still apply.</span></span><span class="equipment-enhancement-specs"><b>+500¥</b><small>Capacity [1]</small></span></label><label class="equipment-enhancement-card"><input type="checkbox"/><span class="equipment-enhancement-check" aria-hidden="true">+</span><span class="equipment-enhancement-copy"><strong>Vision Enhancement</strong><small>CRB</small><p>Improves visual acuity and adds its Rating as a dice-pool bonus to visual Perception Tests.</p><span class="equipment-enhancement-note">Sensor housings require an installed Camera Sensor Function. Capacity and device-rating limits still apply.</span></span><span class="equipment-enhancement-specs"><b>+(Rating x 500)¥</b><small>Capacity [Rating]</small><small>Rating 1-3</small></span></label><label class="equipment-enhancement-card"><input type="checkbox"/><span class="equipment-enhancement-check" aria-hidden="true">+</span><span class="equipment-enhancement-copy"><strong>Vision Magnification</strong><small>CRB</small><p>Provides optical or electronic zoom for distant targets and can help offset range penalties when aiming.</p><span class="equipment-enhancement-note">Sensor housings require an installed Camera Sensor Function. Capacity and device-rating limits still apply.</span></span><span class="equipment-enhancement-specs"><b>+250¥</b><small>Capacity [1]</small></span></label></div></section></div><aside class="equipment-build-summary" aria-live="polite"><div><span>Configured purchase</span><strong>Camera</strong><small>Base item only</small></div><ul></ul><div class="equipment-build-total"><span>Fixed subtotal</span><strong>Use listed line-item costs</strong></div></aside></div></details><section class="section"><div class="source-book-list" aria-label="Source book"><div class="source-book"><span class="source-code">CRB</span><strong class="source-title">Shadowrun Fifth Edition Core Rulebook</strong></div></div></section>",
  "support": "<article class="weapon-support-dossier" aria-labelledby="weapon-support-effect-title"><div class="weapon-support-price"><span>Listed cost</span><strong>125¥</strong><small>2 availability</small></div><section><span>Effect</span><h2 id="weapon-support-effect-title">Laser Sight</h2><p>Projects an aiming point onto the target and improves Accuracy when the dot is visible and the sight is used properly.</p></section></article><div class="weapon-data-grid"><div class="weapon-data-field"><span class="field-label">Support type</span><strong>Firearm Accessories</strong></div><div class="weapon-data-field"><span class="field-label">Mount</span><strong>Top or Under</strong></div><div class="weapon-data-field"><span class="field-label">Availability</span><strong>2</strong></div></div><details class="weapon-related-disclosure"><summary><span>Applicable weapons</span><strong>95</strong></summary><div class="weapon-related-content"><p class="compatibility-note"><strong>Firearms and heavy weapons //</strong> This list is generated from weapon type and feed data. Confirm available mounts, factory-installed features and individual exceptions before purchase.</p><div class="applicable-weapon-groups"><section><h3>Assault Rifles</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ak 98</span><small>Assault Rifles</small></button><button class="related-record-button" type="button"><span>AK-97</span><small>Assault Rifles</small></button><button class="related-record-button" type="button"><span>Ares Alpha</span><small>Assault Rifles</small></button><button class="related-record-button" type="button"><span>Ares Hvar</span><small>Assault Rifles</small></button><button class="related-record-button" type="button"><span>Colt M23</span><small>Assault Rifles</small></button><button class="related-record-button" type="button"><span>FN HAR</span><small>Assault Rifles</small></button><button class="related-record-button" type="button"><span>Hk Xm30</span><small>Assault Rifles</small></button><button class="related-record-button" type="button"><span>Nissan Optimum Ii</span><small>Assault Rifles</small></button><button class="related-record-button" type="button"><span>Yamaha Raiden</span><small>Assault Rifles</small></button></div></section><section><h3>Cannons/Launchers</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ares Antioch 2</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Ares Thunderstruck Gauss Rifle</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Ares Vigorous Assault Cannon</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Armtech Mgl 12</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Aztechnology Striker</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Krime Cannon</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Mitsubishi Yakusoku Mrl</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Ogre Hammer Sws Assault Cannon</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Onotari Arms Ballista Mml</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Onotari Interceptor</span><small>Cannons/Launchers</small></button><button class="related-record-button" type="button"><span>Panther XXL</span><small>Cannons/Launchers</small></button></div></section><section><h3>Exotic Ranged Weapons</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ares Screech Sonic Rifle</span><small>Exotic Ranged Weapons</small></button><button class="related-record-button" type="button"><span>Fn Aal Gyrojet Pistol</span><small>Exotic Ranged Weapons</small></button><button class="related-record-button" type="button"><span>Knockoff Gun Cane</span><small>Exotic Ranged Weapons</small></button><button class="related-record-button" type="button"><span>Mortimer Of London Trafalger Gun Cane</span><small>Exotic Ranged Weapons</small></button><button class="related-record-button" type="button"><span>Tiffani Elegance Shooting Bracers</span><small>Exotic Ranged Weapons</small></button></div></section><section><h3>Heavy Pistols</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ares Predator V</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Ares Viper Slivergun</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Browning Ultra Power</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Cavalier Deputy</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Colt Government 2066</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Onotari Arms Violator</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Psk 3 Collapsible Heavy Pistol</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Remington Roomsweeper</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Ruger Super Warhawk</span><small>Heavy Pistols</small></button><button class="related-record-button" type="button"><span>Savalette Guardian</span><small>Heavy Pistols</small></button></div></section><section><h3>Hold-Outs</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Fichetti Tiffani Needler</span><small>Hold-Outs</small></button><button class="related-record-button" type="button"><span>Fichetti Tiffani Self Defender 2075</span><small>Hold-Outs</small></button><button class="related-record-button" type="button"><span>Streetline Special</span><small>Hold-Outs</small></button><button class="related-record-button" type="button"><span>Walther Palm Pistol</span><small>Hold-Outs</small></button></div></section><section><h3>Light Pistols</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ares Light Fire 70</span><small>Light Pistols</small></button><button class="related-record-button" type="button"><span>Ares Light Fire 75</span><small>Light Pistols</small></button><button class="related-record-button" type="button"><span>Beretta 201T</span><small>Light Pistols</small></button><button class="related-record-button" type="button"><span>Colt America L36</span><small>Light Pistols</small></button><button class="related-record-button" type="button"><span>Fichetti Executive Action</span><small>Light Pistols</small></button><button class="related-record-button" type="button"><span>Fichetti Security 600</span><small>Light Pistols</small></button><button class="related-record-button" type="button"><span>Nitama Sporter</span><small>Light Pistols</small></button><button class="related-record-button" type="button"><span>Shiawase Arms Puzzler</span><small>Light Pistols</small></button><button class="related-record-button" type="button"><span>Taurus Omni 6</span><small>Light Pistols</small></button></div></section><section><h3>Machine Guns</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Fn Mag 5</span><small>Machine Guns</small></button><button class="related-record-button" type="button"><span>Ge Vindicator Mini Gun</span><small>Machine Guns</small></button><button class="related-record-button" type="button"><span>Ingram Valiant</span><small>Machine Guns</small></button><button class="related-record-button" type="button"><span>RPK HMG</span><small>Machine Guns</small></button><button class="related-record-button" type="button"><span>Ruhrmetall Sf 20</span><small>Machine Guns</small></button><button class="related-record-button" type="button"><span>Sa Nemesis</span><small>Machine Guns</small></button><button class="related-record-button" type="button"><span>Stoner-Ares M202</span><small>Machine Guns</small></button><button class="related-record-button" type="button"><span>Ultamax Hmg 2</span><small>Machine Guns</small></button><button class="related-record-button" type="button"><span>Ultamax Mmg</span><small>Machine Guns</small></button></div></section><section><h3>Machine Pistols</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ares Crusader Ii</span><small>Machine Pistols</small></button><button class="related-record-button" type="button"><span>Ceska Black Scorpion</span><small>Machine Pistols</small></button><button class="related-record-button" type="button"><span>Onotari Arms Equalizer</span><small>Machine Pistols</small></button><button class="related-record-button" type="button"><span>Ppsk 4 Collapsible Machine Pistol</span><small>Machine Pistols</small></button><button class="related-record-button" type="button"><span>Steyr TMP</span><small>Machine Pistols</small></button><button class="related-record-button" type="button"><span>Ultimax 70</span><small>Machine Pistols</small></button></div></section><section><h3>Shotguns</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Auto Assault 16</span><small>Shotguns</small></button><button class="related-record-button" type="button"><span>Defiance T-250</span><small>Shotguns</small></button><button class="related-record-button" type="button"><span>Enfield AS-7</span><small>Shotguns</small></button><button class="related-record-button" type="button"><span>Franchi Spas 24</span><small>Shotguns</small></button><button class="related-record-button" type="button"><span>Mossberg Am Cmdt</span><small>Shotguns</small></button><button class="related-record-button" type="button"><span>PJSS Model 55</span><small>Shotguns</small></button><button class="related-record-button" type="button"><span>Remington 990</span><small>Shotguns</small></button></div></section><section><h3>Sniper Rifles</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ares Desert Strike</span><small>Sniper Rifles</small></button><button class="related-record-button" type="button"><span>Barret Model 122</span><small>Sniper Rifles</small></button><button class="related-record-button" type="button"><span>Cavalier Arms Crockett EBR</span><small>Sniper Rifles</small></button><button class="related-record-button" type="button"><span>Onotari Arms Jp K50</span><small>Sniper Rifles</small></button><button class="related-record-button" type="button"><span>Pioneer 60</span><small>Sniper Rifles</small></button><button class="related-record-button" type="button"><span>Ranger Arms SM-5</span><small>Sniper Rifles</small></button><button class="related-record-button" type="button"><span>Remington 950</span><small>Sniper Rifles</small></button><button class="related-record-button" type="button"><span>Ruger 100</span><small>Sniper Rifles</small></button><button class="related-record-button" type="button"><span>Terracotta Arms Am 47</span><small>Sniper Rifles</small></button></div></section><section><h3>Special Weapons</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ares S-III Super Squirt</span><small>Special Weapons</small></button><button class="related-record-button" type="button"><span>Fichetti Pain Inducer</span><small>Special Weapons</small></button><button class="related-record-button" type="button"><span>Parashield Dart Pistol</span><small>Special Weapons</small></button><button class="related-record-button" type="button"><span>Parashield Dart Rifle</span><small>Special Weapons</small></button></div></section><section><h3>Submachine Guns</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Ares Executioner</span><small>Submachine Guns</small></button><button class="related-record-button" type="button"><span>Colt Cobra TZ-120</span><small>Submachine Guns</small></button><button class="related-record-button" type="button"><span>FN P93 Praetor</span><small>Submachine Guns</small></button><button class="related-record-button" type="button"><span>Hk Urban Combat</span><small>Submachine Guns</small></button><button class="related-record-button" type="button"><span>HK-227</span><small>Submachine Guns</small></button><button class="related-record-button" type="button"><span>Ingram Smartgun X</span><small>Submachine Guns</small></button><button class="related-record-button" type="button"><span>SCK Model 100</span><small>Submachine Guns</small></button><button class="related-record-button" type="button"><span>Uzi IV</span><small>Submachine Guns</small></button></div></section><section><h3>Tasers</h3><div class="related-record-grid"><button class="related-record-button" type="button"><span>Cavalier Safeguard</span><small>Tasers</small></button><button class="related-record-button" type="button"><span>Defiance Ex Shocker</span><small>Tasers</small></button><button class="related-record-button" type="button"><span>Tiffani Defiance Protector</span><small>Tasers</small></button><button class="related-record-button" type="button"><span>Yamaha Pulsar</span><small>Tasers</small></button></div></section></div></div></details><section class="section"><div class="source-book-list" aria-label="Source book"><div class="source-book"><span class="source-code">CRB</span><strong class="source-title">Shadowrun Fifth Edition Core Rulebook</strong></div></div></section>",
  "weapon": "<div class="weapon-data-grid"><div class="weapon-data-field"><span class="field-label">Accuracy</span><strong>5 (7)</strong></div><div class="weapon-data-field"><span class="field-label">Damage</span><strong>8P</strong></div><div class="weapon-data-field"><span class="field-label">Armor penetration</span><strong>-1</strong></div><div class="weapon-data-field"><span class="field-label">Firing mode</span><strong>SA</strong></div><div class="weapon-data-field"><span class="field-label">Recoil compensation</span><strong>—</strong></div><div class="weapon-data-field"><span class="field-label">Ammunition</span><strong>15 (c)</strong></div><div class="weapon-data-field"><span class="field-label">Availability</span><strong>5R</strong></div><div class="weapon-data-field"><span class="field-label">Cost</span><strong>725¥</strong></div></div><section class="weapon-description"><h2 class="section-title">Description</h2><p class="weapon-skill-note"><span>Associated skill</span><strong>Pistols</strong></p><p>The newest iteration of the most popular handgun in the world, especially with mercenaries and shadowrunners. Upgraded with improved ergonomics and handling features, the Ares Predator V includes a smartgun system. Some say that the Ares Predator V isn’t better than other guns in its class, but no one can argue that it has better brand recognition.</p></section><section class="section weapon-related-section"><h2 class="section-title">Compatible weapon support</h2><p class="compatibility-note">Compatibility is based on weapon type, ammunition feed and accessory profile. Existing mounts and factory-installed features may reduce the final options.</p><details class="weapon-related-disclosure"><summary><span>Available attachments</span><strong>12</strong></summary><div class="weapon-related-content"><div class="weapon-support-groups"><section class="weapon-support-group"><header><span>Support class</span><h3>Firearm Accessories</h3></header><div class="weapon-support-card-grid"><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Concealable Holster</strong><span>150¥</span></div><p>A holster designed to hide a pistol more effectively beneath clothing.</p><dl><div><dt>Mount</dt><dd>—</dd></div></dl><button class="related-record-button" type="button"><span>Concealable Holster</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Gas-Vent System</strong><span>Rating x 200¥</span></div><p>A barrel-mounted gas-vent system that provides recoil compensation equal to its Rating.</p><dl><div><dt>Mount</dt><dd>Barrel</dd></div></dl><button class="related-record-button" type="button"><span>Gas-Vent System</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Gyro Mount</strong><span>1,400¥</span></div><p>A wearable stabilization harness that provides substantial recoil compensation for heavy or automatic weapons.</p><dl><div><dt>Mount</dt><dd>Under</dd></div></dl><button class="related-record-button" type="button"><span>Gyro Mount</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Imaging Scope (Firearm Accessory)</strong><span>300¥</span></div><p>A top-mounted imaging device that can accept vision enhancements and can be used to aim without exposing the user&#x27;s head.</p><dl><div><dt>Mount</dt><dd>Top</dd></div></dl><button class="related-record-button" type="button"><span>Imaging Scope (Firearm Accessory)</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Laser Sight</strong><span>125¥</span></div><p>Projects an aiming point onto the target and improves Accuracy when the dot is visible and the sight is used properly.</p><dl><div><dt>Mount</dt><dd>Top or Under</dd></div></dl><button class="related-record-button" type="button"><span>Laser Sight</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Periscope (Firearm Accessory)</strong><span>70¥</span></div><p>A simple weapon-mounted periscope that allows observation and firing from behind cover with reduced exposure.</p><dl><div><dt>Mount</dt><dd>Top</dd></div></dl><button class="related-record-button" type="button"><span>Periscope (Firearm Accessory)</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Quick-Draw Holster</strong><span>175¥</span></div><p>A holster optimized for fast access, making it easier to quick-draw the weapon.</p><dl><div><dt>Mount</dt><dd>—</dd></div></dl><button class="related-record-button" type="button"><span>Quick-Draw Holster</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Silencer/Suppressor</strong><span>500¥</span></div><p>A barrel attachment that reduces the sound and muzzle flash of gunfire, making shots harder to detect.</p><dl><div><dt>Mount</dt><dd>Barrel</dd></div></dl><button class="related-record-button" type="button"><span>Silencer/Suppressor</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Smart Firing Platform</strong><span>2,500¥</span></div><p>An autonomous stabilized weapon platform that can mount and operate a firearm using its own sensor and targeting systems.</p><dl><div><dt>Mount</dt><dd>Under</dd></div></dl><button class="related-record-button" type="button"><span>Smart Firing Platform</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Smartgun System (External)</strong><span>200¥</span></div><p>An external smartgun attachment that provides smartlink functionality to a compatible weapon.</p><dl><div><dt>Mount</dt><dd>Top or Under</dd></div></dl><button class="related-record-button" type="button"><span>Smartgun System (External)</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Smartgun System (Internal)</strong><span>Weapon cost x 2¥</span></div><p>An integrated smartgun system that links the weapon to compatible smartlink gear for enhanced targeting and weapon management.</p><dl><div><dt>Mount</dt><dd>Internal</dd></div></dl><button class="related-record-button" type="button"><span>Smartgun System (Internal)</span><small>Firearm Accessories</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Spare Clip</strong><span>5¥</span></div><p>An empty spare ammunition clip sized for a compatible firearm.</p><dl><div><dt>Mount</dt><dd>—</dd></div></dl><button class="related-record-button" type="button"><span>Spare Clip</span><small>Firearm Accessories</small></button></article></div></section></div></div></details><details class="weapon-related-disclosure"><summary><span>Compatible ammunition</span><strong>12</strong></summary><div class="weapon-related-content"><div class="weapon-support-groups"><section class="weapon-support-group"><header><span>Support class</span><h3>Firearm Ammunition</h3></header><div class="weapon-support-card-grid"><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>APDS</strong><span>120¥ per 10 rounds</span></div><p>Armor-piercing discarding-sabot rounds designed to defeat armor; they reduce the target&#x27;s effective protection substantially.</p><dl><div><dt>Damage</dt><dd>—</dd></div><div><dt>AP</dt><dd>-4</dd></div></dl><button class="related-record-button" type="button"><span>APDS</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Capsule</strong><span>5¥ per 10 rounds</span></div><p>Light rounds carrying a liquid payload. A successful hit, including a grazing hit, ruptures the capsule and exposes the target to the chemical inside. One chemical dose fills five rounds; filling each round requires a Logic + Armorer [Mental] (12, 1 minute) Extended Test. Capsule rounds always use Light Pistol ranges.</p><dl><div><dt>Damage</dt><dd>-4</dd></div><div><dt>AP</dt><dd>+4</dd></div></dl><button class="related-record-button" type="button"><span>Capsule</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>EX-Explosive Rounds</strong><span>120¥ per 10 rounds</span></div><p>Enhanced explosive ammunition with a larger charge than standard explosive rounds, increasing Damage Value by 2 and improving Armor Penetration by 1.</p><dl><div><dt>Damage</dt><dd>+2</dd></div><div><dt>AP</dt><dd>-1</dd></div></dl><button class="related-record-button" type="button"><span>EX-Explosive Rounds</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Explosive Rounds</strong><span>80¥ per 10 rounds</span></div><p>Explosive ammunition that increases Damage Value and improves armor penetration.</p><dl><div><dt>Damage</dt><dd>+1</dd></div><div><dt>AP</dt><dd>-1</dd></div></dl><button class="related-record-button" type="button"><span>Explosive Rounds</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Flechette Rounds</strong><span>65¥ per 10 rounds</span></div><p>A cloud of small darts that increases base damage against unarmored targets but performs poorly against armor.</p><dl><div><dt>Damage</dt><dd>+2</dd></div><div><dt>AP</dt><dd>+5</dd></div></dl><button class="related-record-button" type="button"><span>Flechette Rounds</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Frangible</strong><span>10¥ per 10 rounds</span></div><p>Rounds designed to break apart on hard surfaces. They are less effective against armor and barriers; barriers count double their normal Armor against frangible ammunition.</p><dl><div><dt>Damage</dt><dd>-1</dd></div><div><dt>AP</dt><dd>+4</dd></div></dl><button class="related-record-button" type="button"><span>Frangible</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Gel Rounds</strong><span>25¥ per 10 rounds</span></div><p>Non-lethal impact rounds that convert damage to Stun and can knock targets down.</p><dl><div><dt>Damage</dt><dd>+0S</dd></div><div><dt>AP</dt><dd>+1</dd></div></dl><button class="related-record-button" type="button"><span>Gel Rounds</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Hollow Points</strong><span>70¥ per 10 rounds</span></div><p>Expanding ammunition that increases damage against soft targets but is less effective against armor.</p><dl><div><dt>Damage</dt><dd>+1</dd></div><div><dt>AP</dt><dd>+2</dd></div></dl><button class="related-record-button" type="button"><span>Hollow Points</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Regular Ammunition</strong><span>20¥ per 10 rounds</span></div><p>Standard firearm ammunition with no special damage or armor-piercing modifier.</p><dl><div><dt>Damage</dt><dd>—</dd></div><div><dt>AP</dt><dd>—</dd></div></dl><button class="related-record-button" type="button"><span>Regular Ammunition</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Stick-N-Shock</strong><span>80¥ per 10 rounds</span></div><p>Electrified ammunition that converts the attack to Electricity Stun damage with strong armor penetration.</p><dl><div><dt>Damage</dt><dd>-2S(e)</dd></div><div><dt>AP</dt><dd>-5</dd></div></dl><button class="related-record-button" type="button"><span>Stick-N-Shock</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Tracer Rounds</strong><span>60¥ per 10 rounds</span></div><p>Visible tracer ammunition that helps track sustained automatic fire and can improve certain long bursts.</p><dl><div><dt>Damage</dt><dd>—</dd></div><div><dt>AP</dt><dd>—</dd></div></dl><button class="related-record-button" type="button"><span>Tracer Rounds</span><small>Firearm Ammunition</small></button></article><article class="weapon-support-card"><div class="weapon-support-card-heading"><strong>Tracker</strong><span>150¥ per 10 rounds</span></div><p>A bullet containing an RFID tag. If the attack damages the target, the tag remains lodged in the body; if all damage is resisted, it lodges in the armor. Tracker rounds use either security or stealth RFID tags.</p><dl><div><dt>Damage</dt><dd>-2</dd></div><div><dt>AP</dt><dd>-2</dd></div></dl><button class="related-record-button" type="button"><span>Tracker</span><small>Firearm Ammunition</small></button></article></div></section></div></div></details></section><section class="section"><div class="source-book-list" aria-label="Source book"><div class="source-book"><span class="source-code">CRB</span><strong class="source-title">Shadowrun Fifth Edition Core Rulebook</strong></div></div></section>",
}
`;
